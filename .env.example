# =============================================================
# ANDAMUS - Environment Variables
# Copiaza acest fisier in .env.local si completeaza valorile
# =============================================================

# ── SUPABASE ──────────────────────────────────────────────────
# Gasesti in: Supabase Dashboard → Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://xxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ── STRIPE ────────────────────────────────────────────────────
# Gasesti in: Stripe Dashboard → Developers → API Keys
STRIPE_SECRET_KEY=sk_live_...
# sau pentru testare: sk_test_...

# Webhook secret: Stripe Dashboard → Developers → Webhooks → Signing secret
STRIPE_WEBHOOK_SECRET=whsec_...

# Price IDs: Stripe Dashboard → Products → (selecyeaza produsul) → Pricing → API ID
STRIPE_PREMIUM_PRICE_ID=price_...
STRIPE_DRIVER_PRICE_ID=price_...

# ── URL APLICATIE ─────────────────────────────────────────────
# URL-ul public al aplicatiei (fara slash la final)
# Development: http://localhost:3000
# Productie: https://andamus.it
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ── WEB PUSH NOTIFICATIONS (VAPID) ───────────────────────────
# Genereaza cu: node scripts/generate-vapid-keys.js
NEXT_PUBLIC_VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
# Email-ul administratorului pentru VAPID subject
VAPID_SUBJECT=mailto:contact@andamus.it

# ── NOTE ──────────────────────────────────────────────────────
# Google Maps: configurata direct in next.config.ts
# Google OAuth: configurata in Supabase Dashboard → Auth → Providers → Google
# Phone OTP: configurat in Supabase Dashboard → Auth → Providers → Phone (Twilio)
