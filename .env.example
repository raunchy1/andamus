# Supabase Configuration
# Get these from your Supabase project settings: https://supabase.com/dashboard/project/_/settings/api
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Admin Configuration (comma-separated list of admin emails)
NEXT_PUBLIC_ADMIN_EMAILS=admin1@example.com,admin2@example.com

# Google Maps API Key
# Get from Google Cloud Console: https://console.cloud.google.com/
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=your-google-maps-api-key

# Supabase Access Token (for CLI operations)
# Get from Supabase Dashboard: https://supabase.com/dashboard/account/tokens
SUPABASE_ACCESS_TOKEN=sbp_your-access-token

# Resend API Key for emails
# Get from Resend Dashboard: https://resend.com/api-keys
RESEND_API_KEY=your_resend_key

# Web Push VAPID Keys
# Generate with: npx web-push generate-vapid-keys
NEXT_PUBLIC_VAPID_PUBLIC_KEY=your_vapid_public_key
VAPID_PRIVATE_KEY=your_vapid_private_key
VAPID_SUBJECT=mailto:admin@example.com

# Optional: Analytics and Monitoring
# NEXT_PUBLIC_VERCEL_ANALYTICS_ID=
# NEXT_PUBLIC_SENTRY_DSN=

# PostHog Product Analytics
# Get from PostHog Project Settings: https://eu.posthog.com/project/settings
# NEXT_PUBLIC_POSTHOG_KEY=phc_your_project_key
# NEXT_PUBLIC_POSTHOG_HOST=https://eu.i.posthog.com

# Stripe Configuration
# Get from Stripe Dashboard: https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret
STRIPE_PREMIUM_PRICE_ID=price_your_premium_price_id
STRIPE_DRIVER_PRICE_ID=price_your_driver_price_id
NEXT_PUBLIC_APP_URL=http://localhost:7001

# Optional: Feature Flags
# NEXT_PUBLIC_ENABLE_PREMIUM_FEATURES=false

# Waitlist / Coming Soon mode
# When true, the app is gated behind a coming-soon page and waitlist.
# When false (default), the full app is publicly accessible.
NEXT_PUBLIC_WAITLIST_MODE=false

# Cron Job Secret (generate a secure random string)
# CRON_SECRET=your_secure_random_string
